# Management stack ports
POSTGRES_PORT=5432
ELASTIC_PORT=9200
KIBANA_PORT=5601
MANAGEMENT_PORT=8081

# PostgreSQL
POSTGRES_DB=anipoll_management
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Elasticsearch / Kibana
ELASTIC_VERSION=8.17.3
ELASTIC_JAVA_OPTS=-Xms512m -Xmx512m
ANIPOLL_ELASTICSEARCH_HOSTS=management-elasticsearch:9200
